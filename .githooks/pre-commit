#!/usr/bin/env bash
# AgentLake pre-commit hook — blocks commits containing secrets
#
# Checks staged files for:
#   - API keys (OpenRouter, Anthropic, OpenAI, AWS, etc.)
#   - Private keys, tokens, passwords
#   - .env files that shouldn't be committed

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

BLOCKED=0

# Patterns that indicate leaked secrets
PATTERNS=(
    'sk-or-v1-[a-zA-Z0-9]{20,}'          # OpenRouter API key
    'sk-ant-[a-zA-Z0-9]{20,}'            # Anthropic API key
    'sk-[a-zA-Z0-9]{40,}'                # OpenAI API key
    'AKIA[0-9A-Z]{16}'                    # AWS Access Key
    'ghp_[a-zA-Z0-9]{36}'                # GitHub Personal Access Token
    'gho_[a-zA-Z0-9]{36}'                # GitHub OAuth Token
    'xoxb-[0-9]{10,}-[a-zA-Z0-9]{20,}'   # Slack Bot Token
    'xoxp-[0-9]{10,}-[a-zA-Z0-9]{20,}'   # Slack User Token
    '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'  # Private keys
    'PRIVATE KEY'                          # Private key headers
)

# Files to always block
BLOCKED_FILES=(
    '.env'
    '.env.local'
    '.env.production'
    'credentials.json'
    'service-account.json'
    '*.pem'
    '*.key'
    'id_rsa'
    'id_ed25519'
)

echo -e "${YELLOW}🔒 Checking for secrets...${NC}"

# Check for blocked filenames
for pattern in "${BLOCKED_FILES[@]}"; do
    matches=$(git diff --cached --name-only | grep -E "^${pattern}$|/${pattern}$" 2>/dev/null || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}❌ BLOCKED: Sensitive file staged for commit:${NC}"
        echo "   $matches"
        BLOCKED=1
    fi
done

# Check staged file contents for secret patterns
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
if [ -n "$STAGED_FILES" ]; then
    for pattern in "${PATTERNS[@]}"; do
        # Search staged content (not working directory)
        matches=$(git diff --cached -U0 | grep -E "^\+" | grep -E "$pattern" 2>/dev/null || true)
        if [ -n "$matches" ]; then
            echo -e "${RED}❌ BLOCKED: Potential secret detected in staged changes:${NC}"
            echo "   Pattern: $pattern"
            echo "   Match:   $(echo "$matches" | head -1 | cut -c1-80)..."
            BLOCKED=1
        fi
    done
fi

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo -e "${RED}  COMMIT BLOCKED — secrets detected in staged files${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo ""
    echo "  To fix:"
    echo "    1. Remove the secret from the file"
    echo "    2. Use environment variables instead"
    echo "    3. Add the file to .gitignore"
    echo ""
    echo "  To bypass (NOT recommended):"
    echo "    git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ No secrets detected${NC}"
exit 0
