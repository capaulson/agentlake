# AgentLake Environment Configuration
# Copy to .env and fill in required values

# ============================================================
# Database (PostgreSQL 16 + pgvector)
# ============================================================
POSTGRES_USER=agentlake
POSTGRES_PASSWORD=agentlake_dev_password
POSTGRES_DB=agentlake
DATABASE_URL=postgresql+asyncpg://agentlake:agentlake_dev_password@postgres:5432/agentlake
# For Alembic (sync driver)
DATABASE_URL_SYNC=postgresql://agentlake:agentlake_dev_password@postgres:5432/agentlake
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=agentlake_minio
MINIO_SECRET_KEY=agentlake_minio_secret
MINIO_BUCKET=agentlake-vault
MINIO_SECURE=false
# MinIO console credentials
MINIO_ROOT_USER=agentlake_minio
MINIO_ROOT_PASSWORD=agentlake_minio_secret

# ============================================================
# LLM Gateway (Layer 4B)
# ============================================================
# Internal URL for other services to reach the gateway
LLM_GATEWAY_URL=http://llm-gateway:8001
# Shared secret for internal service-to-service auth
LLM_GATEWAY_SERVICE_TOKEN=dev-internal-service-token-change-in-prod

# ============================================================
# LLM Provider Configuration (ONLY in LLM Gateway container)
# At least ONE provider must have a valid API key
# ============================================================

# --- Anthropic (Direct) ---
# Primary provider for Claude models. Lowest latency.
ANTHROPIC_API_KEY=sk-ant-CHANGEME

# --- OpenRouter ---
# Multi-model gateway. Access Claude, Gemini, Llama, etc. through one key.
# Sign up at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-CHANGEME
# Optional: your site name shown in OpenRouter dashboard
OPENROUTER_SITE_NAME=AgentLake

# --- OpenAI-Compatible (vLLM, Ollama, LM Studio, etc.) ---
# For self-hosted or local models. Disabled by default.
OPENAI_COMPAT_ENABLED=false
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1

# ============================================================
# LLM Model Routing
# ============================================================
# Default models for each task (can be overridden via API)
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_EMBEDDING_MODEL=voyage-3
LLM_EMBEDDING_DIMENSION=1536

# Default provider when model doesn't match any routing pattern
LLM_DEFAULT_PROVIDER=anthropic

# Fallback: if primary provider fails, try these in order
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_CHAIN=anthropic,openrouter

# Task-to-model routing (JSON, or set individually)
# These control which model handles each pipeline task
LLM_TASK_SUMMARIZE_CHUNK=claude-sonnet-4-20250514
LLM_TASK_SUMMARIZE_DOCUMENT=claude-sonnet-4-20250514
LLM_TASK_CLASSIFY_ONTOLOGY=claude-haiku-4-5-20251001
LLM_TASK_EXTRACT_ENTITIES=claude-haiku-4-5-20251001
LLM_TASK_EMBED=voyage-3
LLM_TASK_QUERY_EMBED=voyage-3

# Rate limits
LLM_GLOBAL_RPM=300
LLM_PER_SERVICE_RPM=100
# Per-provider rate limits (JSON)
LLM_PER_PROVIDER_RPM={"anthropic": 300, "openrouter": 200, "openai_compat": 1000}

# Optional: path to advanced routing config YAML
# LLM_PROVIDER_CONFIG_PATH=/app/config/llm_providers.yaml

# ============================================================
# Distiller (Processing Pipeline - Layer 2)
# ============================================================
DISTILLER_CONCURRENCY=4
DISTILLER_MAX_RETRIES=3
DISTILLER_RETRY_BACKOFF=10,60,300
DISTILLER_CHUNK_MAX_TOKENS=1024
DISTILLER_CHUNK_OVERLAP_TOKENS=64

# Incremental reprocessing (see specs/INCREMENTAL_REPROCESSING.md)
INCREMENTAL_SIMILARITY_THRESHOLD=0.85
INCREMENTAL_RECLASSIFY_THRESHOLD=0.20
PROCESSING_VERSION=1.0.0
FORCE_FULL_REPROCESS=false

# ============================================================
# API Server (Layer 4A Backend)
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_LOG_LEVEL=INFO

# ============================================================
# Authentication
# ============================================================
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY_HOURS=24
API_KEY_SALT=dev-api-key-salt-change-in-production
# Default admin API key (hashed on first startup)
DEFAULT_ADMIN_API_KEY=dev-admin-key-change-in-production

# ============================================================
# Frontend (React UI)
# ============================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=AgentLake

# ============================================================
# Observability
# ============================================================
LOG_FORMAT=json
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================
# MCP Server (see specs/MCP_SERVER.md)
# ============================================================
MCP_SERVER_PORT=8002
MCP_SERVER_TRANSPORT=sse
# The MCP server calls the REST API using this key (needs 'agent' role)
MCP_SERVER_API_KEY=dev-mcp-server-key

# ============================================================
# Entity Graph (see specs/ENTITY_GRAPH.md)
# ============================================================
# Apache AGE is a PostgreSQL extension — no separate config needed.
# Graph name (created at startup if missing)
GRAPH_NAME=agentlake_graph
# Max traversal depth allowed via API (safety limit)
GRAPH_MAX_TRAVERSAL_DEPTH=5
